#include <stdio.h>
#define MAX 10
int main() {
    int n, bt[MAX], pr[MAX], rt[MAX], t=0, done=0, i, min, cur;
    int wt[MAX]={0}, tat[MAX};
    printf("Enter no. of processes: ");
    scanf("%d",&n);
    for(i=0;i<n;i++) {
        printf("BT & Priority of P%d: ",i+1);
        scanf("%d%d",&bt[i],&pr[i]);
        rt[i]=bt[i];
    }
    while(done<n) {
        min=999; cur=-1;
        for(i=0;i<n;i++)
            if(rt[i]>0 && pr[i]<min) {
                min=pr[i]; cur=i;
            }
        rt[cur]--;
        t++;
        if(rt[cur]==0) {
            done++;
            tat[cur]=t;
            wt[cur]=tat[cur]-bt[cur];
        }
    }
    printf("\nP\tBT\tPR\tWT\tTAT\n");
    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\t%d\n",i+1,bt[i],pr[i],wt[i],tat[i]);
    return 0;
}

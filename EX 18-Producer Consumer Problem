#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>
sem_t empty,full;
void *producer(){
    printf("Producer produced item\n");
    sem_post(&full);
}
void *consumer(){
    sem_wait(&full);
    printf("Consumer consumed item\n");
}
int main(){
    pthread_t p,c;
    sem_init(&empty,0,1);
    sem_init(&full,0,0);
    pthread_create(&p,NULL,producer,NULL);
    pthread_create(&c,NULL,consumer,NULL);
    pthread_join(p,NULL);
    pthread_join(c,NULL);
}

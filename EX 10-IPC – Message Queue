#include <stdio.h>
#include <sys/ipc.h>
#include <sys/msg.h>

struct msg{ long type; char text[50]; };

int main(){
    int id = msgget(IPC_PRIVATE,0666|IPC_CREAT);
    struct msg m; m.type=1;

    printf("Enter: "); scanf("%s",m.text);
    msgsnd(id,&m,sizeof(m.text),0);
    msgrcv(id,&m,sizeof(m.text),1,0);

    printf("Received: %s\n",m.text);
    msgctl(id,IPC_RMID,NULL);
}

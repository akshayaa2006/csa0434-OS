#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>
int main() {
    int fd;
    char data[] = "Hello OS";
    fd = open("file.txt", O_CREAT | O_WRONLY, 0644);
    if (fd < 0) {
        printf("File opening failed\n");
        return 1;
    }
    write(fd, data, strlen(data));
    close(fd);
    printf("File created and written successfully\n");
    return 0;
}

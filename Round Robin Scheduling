#include <stdio.h>
int main() {
    int n, bt[10], rt[10], tq, t=0, i, done=0;
    printf("Enter no. of processes: ");
    scanf("%d",&n);
    printf("Enter burst times:\n");
    for(i=0;i<n;i++) {
        scanf("%d",&bt[i]);
        rt[i]=bt[i];
    }
    printf("Enter time quantum: ");
    scanf("%d",&tq);
    while(done<n) {
        for(i=0;i<n;i++) {
            if(rt[i]>0) {
                if(rt[i]>tq) {
                    t+=tq;
                    rt[i]-=tq;
                } else {
                    t+=rt[i];
                    rt[i]=0;
                    done++;
                    printf("P%d completed at time %d\n",i+1,t);
                }
            }
        }
    }
    return 0;
}

#include <stdio.h>
int main(){
    int block[3]={100,500,200};
    int process[3]={120,80,300};
    int i,j,max;
    for(i=0;i<3;i++){
        max=-1;
        for(j=0;j<3;j++)
            if(block[j]>=process[i] && (max==-1 || block[j]>block[max]))
                max=j;
        if(max!=-1){
            printf("P%d -> Block %d\n",i+1,max+1);
            block[max]-=process[i];
        }
    }
}

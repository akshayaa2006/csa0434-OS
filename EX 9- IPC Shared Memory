#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <string.h>
int main() {
    int shmid;
    char *data;
    shmid = shmget(IPC_PRIVATE, 50, IPC_CREAT | 0666);
    if (shmid < 0) {
        printf("Shared memory creation failed\n");
        return 1;
    }
    data = (char*) shmat(shmid, NULL, 0);
    if (data == (char*) -1) { 
        printf("Attachment failed\n");
        return 1;
    }
    printf("Enter message: ");
    fgets(data, 50, stdin);  
    printf("Shared Message: %s\n", data);
    shmdt(data);
    shmctl(shmid, IPC_RMID, NULL);
    return 0;
}
